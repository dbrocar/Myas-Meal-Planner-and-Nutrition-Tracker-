// ── NUTRITION ─────────────────────────────────────────────────────────────────

function renderNutrition(){

  var sum=zeroN(); var cnt=0;

  var now=new Date();

  for(var i=0;i<30;i++){

    var d=new Date(now.getFullYear(),now.getMonth(),now.getDate()-i);

    var y=d.getFullYear(),m=d.getMonth(),dd=d.getDate();

    var ds=dateKey(y,m,dd);

    var dow=d.getDay(); var wk=getWK(y,m,dd);

    var dn=DAYS_OF_WEEK[dow];

    var dm=(WEEKS[wk]||{})[dn]||{};

    var slots=["am","pm"];

    for(var s=0;s<2;s++){

      var key=ds+"_"+slots[s];

      if(fedLog[key]){

        cnt++;

        var n=calcMeal(dm[slots[s]],addinsLog[key]||{});

        for(var j=0;j<KEYS.length;j++) sum[KEYS[j]]+=n[KEYS[j]];

      }

    }

  }

  var el=document.getElementById("page-nutrition");

  if(cnt===0){

    el.innerHTML='<div class="empty-state"><div style="font-size:40px;margin-bottom:14px">&#x1F43E;</div>'

      +'<div style="font-size:15px;color:#888">No meals logged yet</div>'

      +'<div style="font-size:12px;color:#555;margin-top:8px">Mark meals as Fed in the Calendar tab</div></div>';

    return;

  }

  var days=Math.round(cnt/2);

  var avg={};

  for(var j=0;j<KEYS.length;j++) avg[KEYS[j]]=sum[KEYS[j]]/(cnt/2);

  var ok=0,low=0,high=0;

  for(var a=0;a<AAFCO.length;a++){

    var cfg=AAFCO[a],v=avg[cfg.k];

    if(v<cfg.min) low++; else if(cfg.max<999&&v>cfg.max) high++; else ok++;

  }

  var html='<div class="summary-box">'

    +'<div class="summary-title">30-Day Nutrition Snapshot</div>'

    +'<div class="summary-sub">'+cnt+' meals &bull; ~'+days+' days &bull; daily average</div>'

    +'<div class="pill-row">'

    +'<div class="s-pill" style="background:rgba(76,175,80,.15);color:#4caf50">&#10003; '+ok+' Optimal</div>'

    +(low>0?'<div class="s-pill" style="background:rgba(244,67,54,.15);color:#f44336">&#9888; '+low+' Low</div>':'')

    +(high>0?'<div class="s-pill" style="background:rgba(255,152,0,.15);color:#ff9800">&#9888; '+high+' High</div>':'')

    +'</div></div>';

  for(var a=0;a<AAFCO.length;a++){

    var cfg=AAFCO[a],v=avg[cfg.k];

    var status=v<cfg.min?"low":(cfg.max<999&&v>cfg.max?"high":"ok");

    var pct=cfg.max<9000?Math.min((v/cfg.max)*100,100):Math.min((v/(cfg.min*1.5))*100,100);

    var disp=v>=10?Math.round(v):v.toFixed(2);

    var range=cfg.max<9000?cfg.min+"&ndash;"+cfg.max:cfg.min+"+";

    var bc=status==="ok"?"#4caf50":status==="low"?"#f44336":"#ff9800";

    var pb=status==="ok"?"rgba(76,175,80,.15)":status==="low"?"rgba(244,67,54,.15)":"rgba(255,152,0,.15)";

    var pt=status==="ok"?"&#10003; OK":status==="low"?"LOW":"HIGH";

    html+='<div class="n-card">'

      +'<div class="n-head"><span class="n-name">'+cfg.label+'</span>'

      +'<span class="n-val">'+disp+' '+cfg.unit

      +'<span class="n-pill" style="background:'+pb+';color:'+bc+'">'+pt+'</span></span></div>'

      +'<div class="bar-bg"><div class="bar-fill" style="width:'+pct+'%;background:'+bc+'"></div></div>'

      +'<div class="n-range">Target: '+range+' '+cfg.unit+'</div></div>';

  }

  el.innerHTML=html;

}

 

