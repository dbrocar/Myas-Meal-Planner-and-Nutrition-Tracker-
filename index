// ── HISTORY ───────────────────────────────────────────────────────────────────

function setHistView(v){ histView=v; renderHistory(); }

 

function navHistory(dir){

  if(histView==="week"){

    var nd=addDays(histYear,histMonth,histDay,dir*7);

    histYear=nd.y; histMonth=nd.m; histDay=nd.d;

  } else if(histView==="month"){

    var dt=new Date(histYear,histMonth+dir,1);

    histYear=dt.getFullYear(); histMonth=dt.getMonth();

  } else {

    histYear+=dir;

  }

  renderHistory();

}

 

function jumpToMonth(y,m){ histYear=y; histMonth=m; histView="month"; renderHistory(); }

 

function renderHistory(){

  var views=["week","month","year"];

  var toggle='<div class="view-toggle">';

  for(var i=0;i<views.length;i++){

    var v=views[i];

    var lbl=v==="week"?"Week":v==="month"?"Month":"Year";

    toggle+='<button class="view-btn'+(histView===v?" active":"")+'" onclick="setHistView(\''+v+'\')">'+lbl+'</button>';

  }

  toggle+='</div>';

 

  var navLabel="";

  if(histView==="week"){

    var st=startOfWeek(histYear,histMonth,histDay);

    var en=addDays(st.y,st.m,st.d,6);

    navLabel=monthAbbrev(st.m)+" "+st.d+" &ndash; "+monthAbbrev(en.m)+" "+en.d+(en.y!==st.y?", "+en.y:"");

  } else if(histView==="month"){

    navLabel=monthAbbrev(histMonth)+" "+histYear;

  } else {

    navLabel=String(histYear);

  }

 

  var nav='<div class="hist-nav-row">'

    +'<button class="nav-btn" onclick="navHistory(-1)">&#8249;</button>'

    +'<div class="hist-period-label">'+navLabel+'</div>'

    +'<button class="nav-btn" onclick="navHistory(1)">&#8250;</button>'

    +'</div>';

 

  var content="";

  if(histView==="week")  content=buildWeekView();

  if(histView==="month") content=buildMonthView();

  if(histView==="year")  content=buildYearView();

 

  document.getElementById("page-history").innerHTML = toggle+nav+content;

}

 

function buildWeekView(){

  var st=startOfWeek(histYear,histMonth,histDay);

  var html="";

  for(var i=0;i<7;i++){

    var dt=addDays(st.y,st.m,st.d,i);

    var ds=dateKey(dt.y,dt.m,dt.d);

    var dow=getDOW(dt.y,dt.m,dt.d);

    var dn=DAYS_OF_WEEK[dow];

    var wk=getWK(dt.y,dt.m,dt.d);

    var dm=(WEEKS[wk]||{})[dn]||{};

    var amFed=!!fedLog[ds+"_am"];

    var pmFed=!!fedLog[ds+"_pm"];

    var note=notesLog[ds]||"";

    var isToday=(dt.y===today.getFullYear()&&dt.m===today.getMonth()&&dt.d===today.getDate());

    var notePreview = note ? ("&#128221; "+escapeHtml(note.length>70?note.slice(0,70)+"…":note)) : "+ Add note";

 

    html+='<div class="week-day-row'+(isToday?" today":"")+'">'

      +'<div class="week-day-name">'+dn+' &middot; '+monthAbbrev(dt.m)+' '+dt.d+'</div>'

      +'<div class="week-meals">'

      +'<div class="week-meal-pill'+(amFed?" fed":"")+'">'+(amFed?"&#10003; ":"")+'AM: '+(dm.am?dm.am.protein:"&mdash;")+'</div>'

      +'<div class="week-meal-pill'+(pmFed?" fed":"")+'">'+(pmFed?"&#10003; ":"")+'PM: '+(dm.pm?dm.pm.protein:"&mdash;")+'</div>'

      +'</div>'

      +'<div class="week-note" onclick="openDayDetail(\''+ds+'\')">'+notePreview+'</div>'

      +'</div>';

  }

  return html;

}

 

function buildMonthView(){

  var y=histYear, m=histMonth;

  var firstDow=getDOW(y,m,1);

  var daysInMonth=new Date(y,m+1,0).getDate();

 

  var html='<div class="month-weekdays">';

  var wd=["S","M","T","W","T","F","S"];

  for(var i=0;i<7;i++) html+='<div class="month-weekday-cell">'+wd[i]+'</div>';

  html+='</div><div class="month-grid">';

 

  for(var i=0;i<firstDow;i++) html+='<div class="month-cell empty"></div>';

 

  for(var d=1; d<=daysInMonth; d++){

    var ds=dateKey(y,m,d);

    var amFed=!!fedLog[ds+"_am"];

    var pmFed=!!fedLog[ds+"_pm"];

    var hasNote=!!notesLog[ds];

    var isToday=(y===today.getFullYear()&&m===today.getMonth()&&d===today.getDate());

    var fc=(amFed?1:0)+(pmFed?1:0);

    var cls="month-cell"+(isToday?" today":"")+(fc===2?" full-fed":fc===1?" half-fed":"");

    html+='<div class="'+cls+'" onclick="openDayDetail(\''+ds+'\')">'

      +'<div class="month-cell-day">'+d+'</div>'

      +'<div class="month-cell-dots"><span class="m-dot'+(amFed?" on":"")+'"></span><span class="m-dot'+(pmFed?" on":"")+'"></span></div>'

      +(hasNote?'<div class="note-dot"></div>':'')

      +'</div>';

  }

  html+='</div>';

  return html;

}

 

function buildYearView(){

  var y=histYear;

  var html='<div class="year-grid">';

  for(var m=0;m<12;m++){

    var daysInMonth=new Date(y,m+1,0).getDate();

    var firstDow=getDOW(y,m,1);

    html+='<div class="mini-month" onclick="jumpToMonth('+y+','+m+')">'

      +'<div class="mini-month-label">'+monthAbbrev(m)+'</div>'

      +'<div class="mini-grid">';

    for(var i=0;i<firstDow;i++) html+='<span class="mini-cell empty"></span>';

    for(var d=1; d<=daysInMonth; d++){

      var ds=dateKey(y,m,d);

      var amFed=!!fedLog[ds+"_am"];

      var pmFed=!!fedLog[ds+"_pm"];

      var fc=(amFed?1:0)+(pmFed?1:0);

      var cls="mini-cell"+(fc===2?" full":fc===1?" half":"");

      html+='<span class="'+cls+'"></span>';

    }

    html+='</div></div>';

  }

  html+='</div>';

  return html;

}

 

function openDayDetail(ds){

  var parts=ds.split("-");

  var y=parseInt(parts[0],10), m=parseInt(parts[1],10), d=parseInt(parts[2],10);

  var dow=getDOW(y,m,d), wk=getWK(y,m,d), dn=DAYS_OF_WEEK[dow];

  var dm=(WEEKS[wk]||{})[dn]||{};

  var amFed=!!fedLog[ds+"_am"], pmFed=!!fedLog[ds+"_pm"];

  var note=notesLog[ds]||"";

  var label=fmtDate(y,m,d);

 

  var html='<div class="overlay" id="ddbg"><div class="modal">'

    +'<div class="modal-head"><div class="modal-title">'+label+'</div>'

    +'<button class="modal-close" onclick="closeDayDetail()">&#10005;</button></div>';

 

  html+='<div class="day-detail-meal"><div class="dd-label">AM'+(amFed?" &#10003; Fed":" &mdash; not fed")+'</div>'

    +(dm.am?('<div class="dd-protein">'+dm.am.protein+'</div><div class="dd-detail">'+dm.am.starch+' &middot; '+dm.am.veg+(dm.am.organ?' &middot; '+dm.am.organ:'')+'</div>'):'<div class="dd-detail">No meal scheduled</div>')

    +'</div>';

 

  html+='<div class="day-detail-meal"><div class="dd-label">PM'+(pmFed?" &#10003; Fed":" &mdash; not fed")+'</div>'

    +(dm.pm?('<div class="dd-protein">'+dm.pm.protein+'</div><div class="dd-detail">'+dm.pm.starch+' &middot; '+dm.pm.veg+(dm.pm.organ?' &middot; '+dm.pm.organ:'')+'</div>'):'<div class="dd-detail">No meal scheduled</div>')

    +'</div>';

 

  html+='<div class="modal-hint" style="margin-top:10px">Notes</div>'

    +'<textarea id="noteInput" class="note-textarea" placeholder="Add a note for this day...">'+escapeHtml(note)+'</textarea>'

    +'<button class="save-btn" onclick="saveDayNote(\''+ds+'\')">Save Note</button>';

 

  html+='</div></div>';

 

  document.getElementById("modal-root").innerHTML=html;

  document.getElementById("ddbg").addEventListener("click",function(e){ if(e.target===this) closeDayDetail(); });

}

 

function closeDayDetail(){ document.getElementById("modal-root").innerHTML=""; }

 

function saveDayNote(ds){

  var el=document.getElementById("noteInput");

  var v=el?el.value.trim():"";

  if(v) notesLog[ds]=v; else delete notesLog[ds];

  try{localStorage.setItem("mya_notes",JSON.stringify(notesLog));}catch(e){}

  closeDayDetail();

  renderHistory();

}

 

