<!DOCTYPE html>

<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

<title>Mya's Meal Planner 🐾</title>

<style>

*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}

body{background:#0f1720;color:#e8dcc8;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;min-height:100vh;}

.header{background:#0a1018;padding:14px 20px 0;border-bottom:1px solid rgba(200,147,58,0.25);position:sticky;top:0;z-index:100;}

.header-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}

.app-title{font-size:19px;font-weight:700;color:#c8933a;}

.app-sub{font-size:10px;color:#666;margin-bottom:10px;}

.tabs{display:flex;}

.tab{flex:1;padding:9px 1px;font-size:10px;font-weight:600;color:#666;background:transparent;border:none;border-bottom:2px solid transparent;cursor:pointer;letter-spacing:.1px;}

.tab.active{color:#c8933a;border-bottom-color:#c8933a;}

.page{padding:14px;padding-bottom:80px;display:none;}

.page.active{display:block;}

/* Plan tab */

.section-title{font-size:13px;font-weight:700;color:#c8933a;margin-bottom:10px;margin-top:4px;}

.aafco-group{margin-bottom:14px;}

.aafco-group-label{font-size:10px;font-weight:700;color:#555;letter-spacing:1px;text-transform:uppercase;margin-bottom:6px;}

.aafco-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px;}

.aafco-cell{background:#1a2535;border-radius:7px;padding:7px 9px;}

.aafco-cell-name{font-size:10px;color:#888;margin-bottom:2px;}

.aafco-cell-val{font-size:12px;font-weight:700;color:#e8dcc8;}

/* Rotation */

.rotation-week{background:#1a2535;border-radius:12px;padding:12px;margin-bottom:10px;}

.rotation-week-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}

.rotation-week-title{font-size:13px;font-weight:700;color:#e8dcc8;}

.fish-badge{font-size:10px;font-weight:700;padding:3px 8px;border-radius:99px;background:rgba(33,150,243,0.2);color:#64b5f6;}

.rotation-row{display:flex;gap:5px;overflow-x:auto;padding-bottom:4px;}

.day-cell{flex-shrink:0;width:44px;border-radius:8px;padding:6px 4px;text-align:center;}

.day-cell.land{background:#0f1a28;}

.day-cell.fish{background:rgba(33,150,243,0.15);border:1px solid rgba(100,181,246,0.3);}

.day-cell-name{font-size:9px;font-weight:700;color:#888;margin-bottom:4px;}

.day-cell-am{font-size:9px;color:#e8dcc8;line-height:1.3;margin-bottom:2px;}

.day-cell-pm{font-size:9px;color:#888;line-height:1.3;}

.fish-icon{font-size:11px;}

/* Calendar */

.date-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;background:#1a2535;border-radius:12px;padding:11px 14px;}

.nav-btn{background:rgba(200,147,58,0.15);border:1px solid rgba(200,147,58,0.3);color:#c8933a;border-radius:8px;padding:7px 16px;font-size:20px;cursor:pointer;line-height:1;}

.date-center{text-align:center;}

.date-main{font-size:15px;font-weight:700;}

.date-sub{font-size:10px;color:#888;margin-top:2px;}

.meal-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}

.meal-card{background:#1a2535;border:1px solid rgba(200,147,58,0.2);border-radius:12px;padding:11px;}

.meal-card.fed{background:#1a2f1a;border-color:rgba(76,175,80,0.4);}

.slot-label{font-size:9px;font-weight:700;color:#666;letter-spacing:1px;text-transform:uppercase;margin-bottom:5px;}

.meal-protein{font-size:13px;font-weight:700;margin-bottom:3px;line-height:1.3;}

.meal-details{font-size:10px;color:#888;line-height:1.6;}

.addin-tags{margin-top:6px;padding:5px 7px;background:rgba(200,147,58,0.08);border-radius:6px;}

.addin-tag{font-size:10px;color:#c8933a;}

.addins-btn{width:100%;margin-top:7px;padding:6px 0;background:transparent;border:1px solid rgba(200,147,58,0.35);color:#c8933a;border-radius:7px;font-size:10px;cursor:pointer;}

.fed-btn{width:100%;margin-top:7px;padding:8px 0;border:none;border-radius:7px;font-size:11px;font-weight:700;cursor:pointer;background:#c8933a;color:#0f1720;}

.fed-btn.active{background:#4caf50;color:#fff;}

/* Nutrition */

.summary-box{background:#1a2535;border-radius:12px;padding:13px;margin-bottom:10px;}

.summary-title{font-size:13px;font-weight:700;margin-bottom:3px;}

.summary-sub{font-size:10px;color:#888;margin-bottom:8px;}

.pill-row{display:flex;gap:7px;flex-wrap:wrap;}

.s-pill{padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;}

.n-card{background:#1a2535;border-radius:9px;padding:11px;margin-bottom:7px;}

.n-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;}

.n-name{font-size:12px;font-weight:700;}

.n-val{font-size:10px;}

.n-pill{display:inline-block;padding:2px 6px;border-radius:99px;font-size:9px;font-weight:700;margin-left:5px;}

.bar-bg{height:5px;background:#0a1018;border-radius:3px;margin-bottom:3px;overflow:hidden;}

.bar-fill{height:100%;border-radius:3px;}

.n-range{font-size:9px;color:#555;}

/* Guide */

.guide-card{background:#1a2535;border-radius:12px;padding:14px;margin-bottom:10px;}

.guide-title{font-size:14px;font-weight:700;color:#c8933a;margin-bottom:10px;}

.guide-section{font-size:9px;font-weight:700;color:#555;letter-spacing:1px;text-transform:uppercase;margin-top:10px;margin-bottom:5px;}

.guide-item{font-size:12px;color:#b0a090;line-height:1.9;padding-left:4px;}

.guide-item.warn{color:#ff9800;}

.guide-item.avoid{color:#f44336;}

.guide-item.opt{color:#666;}

.protein-row{display:flex;gap:8px;align-items:center;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.05);}

.protein-name{font-size:12px;flex:1;}

.protein-tag{font-size:9px;padding:2px 6px;border-radius:99px;font-weight:700;}

.tag-lean{background:rgba(76,175,80,0.15);color:#4caf50;}

.tag-mod{background:rgba(200,147,58,0.15);color:#c8933a;}

.tag-high{background:rgba(244,67,54,0.15);color:#f44336;}

.organ-row{display:grid;grid-template-columns:1fr auto auto;gap:8px;align-items:center;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.05);}

.organ-name{font-size:12px;}

.organ-freq{font-size:10px;color:#888;text-align:right;}

.organ-note{font-size:9px;color:#555;text-align:right;}

/* Modal */

.overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.8);z-index:200;display:flex;align-items:flex-end;}

.modal{background:#1a2535;border-radius:16px 16px 0 0;width:100%;padding:20px;max-height:78vh;overflow-y:auto;}

.modal-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}

.modal-title{font-size:15px;font-weight:700;color:#c8933a;}

.modal-close{background:transparent;border:none;color:#888;font-size:22px;cursor:pointer;line-height:1;}

.modal-hint{font-size:11px;color:#666;margin-bottom:12px;}

.ai-row{display:flex;align-items:center;padding:9px 0;border-bottom:1px solid rgba(255,255,255,0.06);}

.ai-name{font-size:13px;flex:1;}

.ai-input{width:56px;padding:6px 8px;background:#0f1720;border:1px solid rgba(200,147,58,0.3);border-radius:7px;color:#e8dcc8;font-size:14px;text-align:center;}

.ai-unit{font-size:10px;color:#666;margin-left:5px;}

.save-btn{width:100%;padding:13px;background:#c8933a;border:none;border-radius:10px;color:#0f1720;font-size:15px;font-weight:700;cursor:pointer;margin-top:14px;}

.empty-state{text-align:center;padding-top:60px;}

/* History */

.view-toggle{display:flex;gap:6px;margin-bottom:12px;}

.view-btn{flex:1;padding:9px 0;border-radius:9px;border:1px solid rgba(200,147,58,0.3);background:transparent;color:#888;font-size:12px;font-weight:700;cursor:pointer;}

.view-btn.active{background:#c8933a;color:#0f1720;border-color:#c8933a;}

.hist-nav-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;background:#1a2535;border-radius:12px;padding:10px 14px;}

.hist-period-label{font-size:14px;font-weight:700;text-align:center;flex:1;}

.week-day-row{background:#1a2535;border-radius:10px;padding:10px 12px;margin-bottom:8px;}

.week-day-row.today{border:1px solid rgba(200,147,58,0.5);}

.week-day-name{font-size:12px;font-weight:700;color:#e8dcc8;}

.week-meals{display:flex;gap:8px;margin-top:7px;}

.week-meal-pill{flex:1;font-size:10px;padding:6px 8px;border-radius:7px;background:#0f1720;color:#888;}

.week-meal-pill.fed{background:rgba(76,175,80,0.15);color:#4caf50;}

.week-note{margin-top:8px;font-size:11px;color:#c8933a;padding:7px 9px;background:rgba(200,147,58,0.06);border-radius:7px;cursor:pointer;word-break:break-word;}

.month-weekdays{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:6px;}

.month-weekday-cell{text-align:center;font-size:10px;color:#666;font-weight:700;}

.month-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;}

.month-cell{aspect-ratio:1;background:#1a2535;border-radius:8px;padding:4px;position:relative;cursor:pointer;}

.month-cell.empty{background:transparent;cursor:default;}

.month-cell.today{border:1px solid #c8933a;}

.month-cell.full-fed{background:rgba(76,175,80,0.12);}

.month-cell.half-fed{background:rgba(255,152,0,0.10);}

.month-cell-day{font-size:11px;font-weight:600;color:#e8dcc8;}

.month-cell-dots{display:flex;gap:3px;margin-top:4px;}

.m-dot{width:5px;height:5px;border-radius:50%;background:#3a3a4a;}

.m-dot.on{background:#4caf50;}

.note-dot{position:absolute;top:4px;right:4px;width:5px;height:5px;border-radius:50%;background:#c8933a;}

.year-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}

.mini-month{background:#1a2535;border-radius:10px;padding:8px;cursor:pointer;}

.mini-month-label{font-size:11px;font-weight:700;color:#c8933a;margin-bottom:5px;text-align:center;}

.mini-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;}

.mini-cell{aspect-ratio:1;border-radius:2px;background:#0f1720;}

.mini-cell.empty{background:transparent;}

.mini-cell.full{background:#4caf50;}

.mini-cell.half{background:#ff9800;}

.dd-label{font-size:10px;font-weight:700;color:#888;letter-spacing:1px;text-transform:uppercase;margin-bottom:3px;}

.dd-protein{font-size:14px;font-weight:700;margin-bottom:2px;}

.dd-detail{font-size:11px;color:#888;margin-bottom:4px;}

.day-detail-meal{padding:9px 0;border-bottom:1px solid rgba(255,255,255,0.06);}

.note-textarea{width:100%;min-height:90px;background:#0f1720;border:1px solid rgba(200,147,58,0.3);border-radius:8px;color:#e8dcc8;font-size:13px;padding:10px;font-family:inherit;resize:vertical;margin-top:8px;}

</style>

</head>

