function dateKey(y,m,d){ return y+"-"+(m<10?"0"+m:m)+"-"+(d<10?"0"+d:d); }

function getDOW(y,m,d){ return new Date(y,m,d).getDay(); }

function getWK(y,m,d){

  var jan1 = new Date(y,0,1);

  var doy  = Math.round((new Date(y,m,d)-jan1)/86400000);

  return (Math.floor(doy/7)%4)+1;

}

function fmtDate(y,m,d){

  var wdays=["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];

  var mons=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];

  return wdays[getDOW(y,m,d)]+", "+mons[m]+" "+d;

}

function advDay(n){

  var dt=new Date(curYear,curMonth,curDay+n);

  curYear=dt.getFullYear(); curMonth=dt.getMonth(); curDay=dt.getDate();

}

function addDays(y,m,d,n){ var dt=new Date(y,m,d+n); return {y:dt.getFullYear(),m:dt.getMonth(),d:dt.getDate()}; }

function monthAbbrev(m){ var mons=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]; return mons[m]; }

function escapeHtml(s){

  return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");

}

function startOfWeek(y,m,d){

  var dow=getDOW(y,m,d);

  var dt=new Date(y,m,d-dow);

  return {y:dt.getFullYear(),m:dt.getMonth(),d:dt.getDate()};

}

 

