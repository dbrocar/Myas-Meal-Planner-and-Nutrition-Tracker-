function zeroN(){ var t={}; for(var i=0;i<KEYS.length;i++) t[KEYS[i]]=0; return t; }

function addFood(t,src,oz){

  if(!src) return;

  for(var i=0;i<KEYS.length;i++) t[KEYS[i]]+=(src[KEYS[i]]||0)*oz;

}

function calcMeal(m,addins){

  var t=zeroN();

  if(m){

    addFood(t,FOODS[m.protein],8);

    addFood(t,FOODS[m.starch],2.5);

    addFood(t,FOODS[m.veg],2.5);

    if(m.organ) addFood(t,FOODS[m.organ],0.5);

    for(var i=0;i<KEYS.length;i++) t[KEYS[i]]+=(SUPPS[KEYS[i]]||0);

  }

  if(addins){

    var ns=Object.keys(addins);

    for(var j=0;j<ns.length;j++){ if(addins[ns[j]]>0) addFood(t,ADDINS[ns[j]],addins[ns[j]]); }

  }

  return t;

}

 

